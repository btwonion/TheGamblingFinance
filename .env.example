# --- Postgres ---
POSTGRES_DB=gamblingfinance
POSTGRES_USER=gamblingfinance
POSTGRES_PASSWORD=change-me-in-prod

# --- Backend ---
# DATABASE_URL is how the API connects to Postgres.
# When running via docker compose, the host is the service name `db`.
# When running the backend directly on the host, point at localhost:5432.
DATABASE_URL=postgres://gamblingfinance:change-me-in-prod@db:5432/gamblingfinance
PORT=8080
# Use a strong, random 32+ byte secret in production (e.g. `openssl rand -hex 32`).
SESSION_SECRET=replace-with-32-byte-random-hex
RUST_LOG=info,gamblingfinance=debug,tower_http=debug

# --- First-boot admin seed (Phase 3 integration consumes these) ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-on-first-login

# --- Frontend (Vite build-time vars; must be prefixed VITE_) ---
# Dev: Vite proxies /api to the backend, so leave this blank.
# Prod: set to the public-facing API origin, e.g. https://api.example.com
VITE_API_BASE=
